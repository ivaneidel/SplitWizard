rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMemberOf(groupId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // User profiles: each user owns their own doc; any signed-in user can read
    // (needed to show member names/avatars).
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Groups: only members can read/update. Creator must include themselves.
    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update, delete: if signedIn() && request.auth.uid in resource.data.memberUids;

      // Expenses / settlements / comments / activity: gated on group membership.
      match /{sub=**} {
        allow read, write: if isMemberOf(groupId);
      }
    }

    // Installment plans: only members of the referenced group.
    match /installmentPlans/{planId} {
      allow read, delete: if signedIn() && isMemberOf(resource.data.groupId);
      allow create: if signedIn() && isMemberOf(request.resource.data.groupId);
    }

    // Per-user budgets.
    match /budgets/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
